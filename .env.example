# =============================================================================
# RecipesAI — переменные окружения
# =============================================================================
# Сайт рецептов + AI (RAG только по документам) + Stripe (5/час бесплатно, платный — без лимита)
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI (для AI-ответов по рецептам)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
# Получить: https://platform.openai.com/api-keys

# -----------------------------------------------------------------------------
# PostgreSQL (пользователи, подписки, рецепты)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/recipes_ai

# -----------------------------------------------------------------------------
# JWT (токены авторизации)
# -----------------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Google OAuth (вход через Google)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Настроить: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:8000/api/v1/auth/callback (или ваш домен)

# -----------------------------------------------------------------------------
# Stripe (оплата подписки)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PREMIUM=price_...
# Получить: https://dashboard.stripe.com/apikeys
# Webhook: создать endpoint на /api/v1/payments/webhook, события checkout.session.completed
# Premium Price: создать Product + Price в Stripe Dashboard

# -----------------------------------------------------------------------------
# Redis (для rate limiting — 5 запросов/час бесплатно)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Без Redis можно использовать in-memory (только для разработки)

# -----------------------------------------------------------------------------
# Векторное хранилище (FAISS / Qdrant — опционально, зависит от реализации)
# -----------------------------------------------------------------------------
# FAISS: файл на диске, ключи не нужны
# Qdrant:
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=...
# QDRANT_COLLECTION=recipes

# -----------------------------------------------------------------------------
# Приложение
# -----------------------------------------------------------------------------
ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
# Для production: ваш фронтенд URL
